<?xml version="1.0" encoding="utf-8"?>
<!-- Dynamic track background coloring behind the Switch thumb -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true" android:color="#00C2FF" /> <!-- Glowing neon-cyan track when checked -->
    <item android:state_checked="false" android:color="#334155" /> <!-- Muted slate track when unchecked -->
</selector>