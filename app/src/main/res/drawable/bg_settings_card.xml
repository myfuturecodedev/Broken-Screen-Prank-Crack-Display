<?xml version="1.0" encoding="utf-8"?>
<!-- Premium rounded card surface container for listing categories with sharp subtle outlines -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#131B2B" /> <!-- Slate surface card color -->
    <stroke
        android:width="1dp"
        android:color="#1E293B" /> <!-- Subtle dark outline boundary -->
    <corners android:radius="18dp" />
</shape>