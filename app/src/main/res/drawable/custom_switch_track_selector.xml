<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_checked="false">
        <layer-list>
            <!-- Outer transparent container -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#334155" />
                    <corners android:radius="100dp" />
                    <size android:width="44dp" android:height="16dp" />
                </shape>
            </item>
            <!-- Inner actual thumb with 4dp padding alignment -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="100dp" />
                    <solid android:color="#94A3B8" />
                    <size android:width="44dp" android:height="16dp" />
                </shape>
            </item>
        </layer-list> <!-- ✅ FIXED: Changed </shape> to </layer-list> to resolve nesting crash -->
    </item>
</selector>