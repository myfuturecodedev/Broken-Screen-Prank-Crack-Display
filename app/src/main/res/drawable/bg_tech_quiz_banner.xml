<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 1: Outer Stroke (Glow Border) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1E3E6B" /> <!-- Subtle glowing cyan-blue border -->
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Layer 2: Inner Background with Premium Gradient (Inset by 1.2dp to preserve sharp stroke borders) -->
    <item
        android:top="1.2dp"
        android:bottom="1.2dp"
        android:left="1.2dp"
        android:right="1.2dp">
        <shape android:shape="rectangle">
            <!--
                Premium dark-blue to electric-cyan linear gradient (0 degrees = left-to-right).
                Using a centerColor ensures smooth progression across wider screens.
            -->
            <gradient
                android:startColor="#0D1A30"
                android:centerColor="#10254C"
                android:endColor="#061224"
                android:angle="0" />
            <corners android:radius="15dp" /> <!-- Slightly smaller radius to match the inset container proportion -->
        </shape>
    </item>

</layer-list>