<?xml version="1.0" encoding="utf-8"?>
<!-- Circular shape for Whatsapp, Messenger, Telegram, and Instagram links -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#26FFFFFF">
    <item>
        <shape android:shape="oval">
            <solid android:color="#1A2436" /> <!-- Slightly darker blue-slate hue -->
            <stroke
                android:width="1dp"
                android:color="#24334C" /> <!-- Soft charcoal edge stroke -->
        </shape>
    </item>
</ripple>