<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lang_bg_dark"
    tools:context=".ui.afterlogin.PreviewScreenFragment">

    <!-- 1. Header Toolbar (Back button, dynamic title & help info) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerToolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_back"
            android:contentDescription="Go Back"
            app:tint="@color/lang_text_white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/preview_effect"
            android:textColor="@color/lang_text_white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnHelpInfo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_help_info"
            android:contentDescription="Help Tooltip"
            app:tint="@color/lang_cyan_glow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- STREAMING_CHUNK:Structuring layout guidelines for phone mockup... -->
    <!-- Symmetrical height guidelines that prevent clipping on extra tall/short screens -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/glTopMargin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.08" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/glBottomMargin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.78" />

    <!-- STREAMING_CHUNK:Configuring phone mockup card mask... -->
    <!-- 2. Centered High-Fidelity Phone Mockup (Responsive & Aspect-Ratio Safe) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clPhoneMockup"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_phone_frame"
        android:padding="3.5dp"
        app:layout_constraintWidth_max="300dp"
        app:layout_constraintHeight_max="600dp"
        app:layout_constraintDimensionRatio="1:2"
        app:layout_constraintTop_toBottomOf="@id/glTopMargin"
        app:layout_constraintBottom_toTopOf="@id/glBottomMargin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- CardView mask to clip mock home wallpapers inside bezel rounded corners -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/lang_card_bg"
            app:cardMaxElevation="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Layer 1: Simulated mobile OS desktop wallpaper with grid icons -->
                <ImageView
                    android:id="@+id/ivMockWallpaper"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/broken_screen_1"
                    android:contentDescription="Simulated OS Background" />

                <!-- Layer 2: Seamless glass crack fracture vector graphic overlaid -->
                <ImageView
                    android:id="@+id/ivMockCrack"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:contentDescription="Glass Fracture Layer" />

                <!-- Layer 3: Diagonal glossy reflection glare effect -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.10" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- STREAMING_CHUNK:Designing call-to-action buttons... -->
    <!-- 3. Bottom Neon Cyan Slogan Label -->
    <TextView
        android:id="@+id/tvFooterSlogan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ready_to_fool_your_friends"
        android:textColor="@color/lang_cyan_glow"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        app:layout_constraintBottom_toTopOf="@id/llBottomButtons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clPhoneMockup"
        app:layout_constraintVertical_bias="0.5" />

    <!-- 4. Twin "Start Prank" Buttons Container (Responsive horizontal flow) -->
    <LinearLayout
        android:id="@+id/llBottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Button Left: Premium Matte Slate Card style with Lightning Icon -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoBack"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_start_prank_card"
            android:text="@string/back"
            android:textColor="@color/lang_text_white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:icon="@drawable/ic_lightning"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconTint="@color/lang_text_white"
            app:backgroundTint="@null" />

        <!-- Button Right: Glowing Neon Cyan Gradient style with Lightning Icon -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartPrankCyan"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_start_prank_btn"
            android:text="@string/start_prank"
            android:textColor="@color/lang_text_white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:icon="@drawable/ic_lightning"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconTint="@color/lang_text_white"
            app:backgroundTint="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>