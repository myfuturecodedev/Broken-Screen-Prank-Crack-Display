<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lang_bg_dark"
    tools:context=".ui.afterlogin.PreviewScreenFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerToolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Go Back"
            android:scaleType="centerInside"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/lang_text_white" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/preview_effect"
            android:textColor="@color/lang_text_white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnHelpInfo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Help Tooltip"
            android:scaleType="centerInside"
            android:src="@drawable/ic_help_info"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/lang_cyan_glow" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 2. Scrollable Body Wrapper -->
    <!-- STREAMING_CHUNK: Creating the scroll viewport... -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerToolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- 3. Centered High-Fidelity Phone Mockup (Aspect Ratio Configured) -->
            <!-- STREAMING_CHUNK: Configuring the mockup frame ratio... -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clPhoneMockup"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_phone_frame"
                android:padding="3.5dp"
                app:layout_constraintDimensionRatio="H,1:2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_max="280dp"
                app:layout_constraintWidth_percent="0.65">

                <!-- Inner CardView clip mask to preserve rounded bezel curves -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardBackgroundColor="@color/lang_card_bg"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardMaxElevation="0dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/ivMockWallpaper"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="Simulated OS Background"
                            android:scaleType="centerCrop"
                            android:src="@drawable/broken_screen_1" />

                        <!-- Layer 2: Seamless glass crack fracture vector graphic overlaid -->
                        <ImageView
                            android:id="@+id/ivMockCrack"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="Glass Fracture Layer"
                            android:scaleType="fitXY" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0.10"
                            android:background="@drawable/gradient_glare_overlay" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 4. Slogan text with dynamic vertical separation -->
            <!-- STREAMING_CHUNK: Aligning responsive slogans... -->
            <TextView
                android:id="@+id/tvFooterSlogan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:text="@string/ready_to_fool_your_friends"
                android:textColor="@color/lang_cyan_glow"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/clPhoneMockup" />

            <!-- 5. Dynamic Double Action Button Row -->
            <!-- STREAMING_CHUNK: Styling action button layouts... -->
            <LinearLayout
                android:id="@+id/llBottomButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="90dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvFooterSlogan">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoBack"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_start_prank_card"
                    android:text="@string/back"
                    android:textAllCaps="false"
                    android:textColor="@color/lang_text_white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_lightning"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconTint="@color/lang_text_white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartPrankCyan"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_start_prank_btn"
                    android:text="@string/start_prank"
                    android:textAllCaps="false"
                    android:textColor="@color/lang_text_white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_lightning"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconTint="@color/lang_text_white" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>