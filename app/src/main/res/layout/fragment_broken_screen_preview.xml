<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lang_bg_dark"
    android:fillViewport="true"
    tools:context=".ui.afterlogin.BrokenScreenPreviewFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="90dp">

        <!-- 1. Top Custom Action Bar Header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/toolbarLayout"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Go Back"
                android:scaleType="centerInside"
                android:src="@drawable/ic_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/lang_text_white" />

            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/broken_screen"
                android:textColor="@color/lang_text_white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/btnHelpInfo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Help"
                android:scaleType="centerInside"
                android:src="@drawable/ic_help_info"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 2. Screen Config Title -->
        <TextView
            android:id="@+id/tvConfigTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/choose_your_effect"
            android:textColor="@color/lang_text_white"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/toolbarLayout" />

        <TextView
            android:id="@+id/tvConfigSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="@string/select_a_realistic_broken_screen_effect"
            android:textColor="@color/lang_text_muted"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvConfigTitle" />


        <View
            android:layout_width="match_parent"
            android:layout_height="400dp"
            app:layout_constraintTop_toBottomOf="@id/tvConfigSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="@drawable/back_ground_preview"/>

        <!-- 3. Dynamic Interactive Phone Preview Carousel (rv_view) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_view"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/tvConfigSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


        <!-- 4. Preview Effect Pill Action Button -->

<!--        <LinearLayout-->
<!--            android:id="@+id/btnPreviewEffect"-->
<!--            android:layout_width="160dp"-->
<!--            android:layout_height="40dp"-->
<!--            android:layout_marginTop="12dp"-->
<!--            android:orientation="horizontal"-->
<!--            android:gravity="center"-->
<!--            android:background="@drawable/bg_preview_effect_btn"-->
<!--            android:clickable="true"-->
<!--            android:focusable="true"-->
<!--            app:layout_constraintEnd_toEndOf="parent"-->
<!--            app:layout_constraintStart_toStartOf="parent"-->
<!--            app:layout_constraintTop_toBottomOf="@id/rv_view">-->

<!--            <ImageView-->
<!--                android:layout_width="18dp"-->
<!--                android:layout_height="18dp"-->
<!--                android:src="@drawable/ic_eye"-->
<!--                android:contentDescription="Eye" />-->

<!--            <TextView-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="Preview Effect"-->
<!--                android:textColor="@color/lang_text_white"-->
<!--                android:textSize="13sp"-->
<!--                android:textStyle="bold"-->
<!--                android:layout_marginStart="8dp" />-->

<!--        </LinearLayout>-->

        <!-- 5. Activation Mode Section Header -->
        <TextView
            android:id="@+id/tvActivationHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="28dp"
            android:text="@string/choose_activation_method"
            android:textColor="@color/lang_text_white"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rv_view" />

        <!-- 6. Card 1: Touch Method -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clMethodTouch"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_activation_card_unselected"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/tvActivationHeader">

            <ImageView
                android:id="@+id/ivTouchIcon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/bg_icon_squircle"
                android:padding="10dp"
                android:src="@drawable/ic_hand_touch"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvTouchTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/touch"
                android:textColor="@color/lang_text_white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/tvTouchSub"
                app:layout_constraintStart_toEndOf="@id/ivTouchIcon"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tvTouchSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tap_screen_to_activate_instantly"
                android:textColor="@color/lang_text_muted"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/tvTouchTitle"
                app:layout_constraintTop_toBottomOf="@id/tvTouchTitle" />

            <!-- Circular Checked custom ring indicator state -->
            <ImageView
                android:id="@+id/ivTouchCheck"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_checkbox_circle"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/vTouchCircle"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/ic_radio_unselected"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 7. Card 2: Shake Method -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clMethodShake"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_activation_card_unselected"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/clMethodTouch">

            <ImageView
                android:id="@+id/ivShakeIcon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/bg_icon_squircle"
                android:padding="10dp"
                android:src="@drawable/ic_shake"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvShakeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/shake"
                android:textColor="@color/lang_text_white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/tvShakeSub"
                app:layout_constraintStart_toEndOf="@id/ivShakeIcon"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tvShakeSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/shake_device_to_trigger_the_prank"
                android:textColor="@color/lang_text_muted"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/tvShakeTitle"
                app:layout_constraintTop_toBottomOf="@id/tvShakeTitle" />

            <ImageView
                android:id="@+id/ivShakeCheck"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_checkbox_circle"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/vShakeCircle"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/ic_radio_unselected"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 8. Card 3: Timer Method -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clMethodTimer"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_activation_card_unselected"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/clMethodShake">

            <ImageView
                android:id="@+id/ivTimerIcon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/bg_icon_squircle"
                android:padding="10dp"
                android:src="@drawable/ic_timer"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvTimerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/timer"
                android:textColor="@color/lang_text_white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/tvTimerSub"
                app:layout_constraintStart_toEndOf="@id/ivTimerIcon"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tvTimerSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activate_automatically_after_a_delay"
                android:textColor="@color/lang_text_muted"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/tvTimerTitle"
                app:layout_constraintTop_toBottomOf="@id/tvTimerTitle" />

            <ImageView
                android:id="@+id/ivTimerCheck"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_checkbox_circle"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/vTimerCircle"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/ic_radio_unselected"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 9. Horizontal Timer Delay tags Selection bar -->
        <HorizontalScrollView
            android:id="@+id/hsvTimerOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:scrollbars="none"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/clMethodTimer"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="4dp">

                <TextView
                    android:id="@+id/tvTimeOff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_timer_tag_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="OFF"
                    android:textColor="@color/lang_text_white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTime10s"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_timer_tag_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="10s"
                    android:textColor="@color/lang_text_white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTime15s"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_timer_tag_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="15s"
                    android:textColor="@color/lang_text_white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTime20s"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_timer_tag_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="20s"
                    android:textColor="@color/lang_text_white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTime30s"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_timer_tag_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="30s"
                    android:textColor="@color/lang_text_white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTime1m"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_timer_tag_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="1m"
                    android:textColor="@color/lang_text_white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTime2m"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_timer_tag_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="2m"
                    android:textColor="@color/lang_text_white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- 10. Pro Tip Warning Box -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clProTipContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_why_share_card"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/hsvTimerOptions">

            <ImageView
                android:id="@+id/ivProTipBulb"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_light_bulb"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvProTipTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/pro_tip"
                android:textColor="@color/lang_text_white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/ivProTipBulb"
                app:layout_constraintStart_toEndOf="@id/ivProTipBulb"
                app:layout_constraintTop_toTopOf="@id/ivProTipBulb" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineHeight="20dp"
                android:text="@string/touch_mode_creates_the_most_realistic_prank_reactions_when_handing_your_phone_to_a_friend"
                android:textColor="@color/lang_text_muted"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivProTipBulb" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <include
            android:id="@+id/native_ads_3"
            layout="@layout/native_ads_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:layout_marginTop="@dimen/_4sdp"
            android:layout_marginBottom="@dimen/_4sdp"
            app:layout_constraintTop_toBottomOf="@+id/clProTipContainer"
            />


        <!-- 11. Footer Label & Start Action CTA -->
        <TextView
            android:id="@+id/tvFooterSlogan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:letterSpacing="0.08"
            android:text="@string/ready_to_fool_your_friends"
            android:textColor="#38BDF8"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/native_ads_3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartPrank"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_next_btn_round"
            android:text="@string/start_prank"
            android:textAllCaps="false"
            android:textColor="@color/lang_text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_lightning"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/lang_text_white"
            app:layout_constraintTop_toBottomOf="@id/tvFooterSlogan" />

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.core.widget.NestedScrollView>