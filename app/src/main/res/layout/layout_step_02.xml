<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="20dp">

    <TextView
        android:id="@+id/tvStep02"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="20dp"
        android:background="@drawable/timeline_step_circle"
        android:gravity="center"
        android:text="@string/_02"
        android:textColor="@color/cyan"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <View
        android:layout_width="2dp"
        android:layout_height="220dp"
        android:background="@color/cyan"
        app:layout_constraintStart_toStartOf="@id/tvStep02"
        app:layout_constraintEnd_toEndOf="@id/tvStep02"
        app:layout_constraintTop_toBottomOf="@id/tvStep02"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="@color/card_dark"
        app:cardCornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tvStep02"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/configure_trigger"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/choose_how_the_prank_should_start"
                android:textColor="@color/text_secondary"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:padding="@dimen/_2sdp"
                android:layout_marginHorizontal="@dimen/_1sdp"
                android:orientation="horizontal">

                <include layout="@layout/item_trigger_touch"/>

                <include layout="@layout/item_trigger_shake"/>

                <include layout="@layout/item_trigger_timer"/>

            </LinearLayout>

            </HorizontalScrollView>



            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShareLink"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_next_btn"
                app:backgroundTint="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/share_link"
                android:textColor="@color/lang_text_white"
                android:textAllCaps="false"
                android:textSize="16sp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>