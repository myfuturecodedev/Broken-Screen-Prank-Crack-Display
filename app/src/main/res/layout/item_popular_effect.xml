<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="144dp"
    android:layout_height="174dp"
    android:layout_marginHorizontal="6dp"
    android:background="@drawable/bg_quick_action_card"
    android:clipToOutline="true">

    <ImageView
        android:id="@+id/ivPopularEffectImg"
        android:layout_width="match_parent"
        android:layout_height="124dp"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvPopularEffectTitle"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:textColor="@color/lang_text_white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:maxLines="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivPopularEffectImg" />

</androidx.constraintlayout.widget.ConstraintLayout>