<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_language_card_unselected"
    android:padding="12dp">

    <!-- Flag circular/square image backdrop matching Figma shadow layer -->
    <FrameLayout
        android:id="@+id/flFlagContainer"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="#1E293B"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Using high resolution emoji flags or scalable flag icons directly -->
        <TextView
            android:id="@+id/tvFlagEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textSize="26sp" />
    </FrameLayout>

    <!-- Language primary native title -->
    <TextView
        android:id="@+id/tvLanguageNative"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:textColor="@color/lang_text_white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tvLanguageEnglish"
        app:layout_constraintEnd_toStartOf="@id/imgRadioIcon"
        app:layout_constraintStart_toEndOf="@id/flFlagContainer"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- English name subtitle -->
    <TextView
        android:id="@+id/tvLanguageEnglish"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/lang_text_muted"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/imgRadioIcon"
        app:layout_constraintStart_toStartOf="@id/tvLanguageNative"
        app:layout_constraintTop_toBottomOf="@id/tvLanguageNative" />

    <!-- Custom vector radio button wrapper -->
    <ImageView
        android:id="@+id/imgRadioIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="4dp"
        android:src="@drawable/ic_radio_unselected"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>